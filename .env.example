OPENROUTER_API_KEY=your_key_here
TELEGRAM_BOT_TOKEN=your_token
STT_API_KEY=your_groq_key
GITHUB_TOKEN=your_github_token
NOTION_API_KEY=your_notion_api_key
SERPAPI_KEY=your_serpapi_key
A2A_AUTH_TOKEN=your_a2a_auth_token
A2A_SIGNING_SECRET=your_hmac_signing_secret

# API Authentication (set to enable bearer-token auth on /api/* endpoints)
PAGAL_API_TOKEN=

# TLS/HTTPS (set both to enable HTTPS on the server)
PAGAL_TLS_CERT=
PAGAL_TLS_KEY=

# Reverse proxy support (set to "true" when behind nginx/Caddy)
PAGAL_BEHIND_PROXY=false

# Sandbox mode: "thread" (default) or "process" (recommended for production)
PAGAL_SANDBOX_MODE=thread

# Logging format: "text" (default) or "json" (for production log aggregation)
PAGAL_LOG_FORMAT=text

# CORS: comma-separated allowed origins (empty = same-origin only)
PAGAL_CORS_ORIGINS=

# OpenTelemetry (set OTEL_ENABLED=true to enable distributed tracing)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pagal-os
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# WhatsApp Business Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=pagal-os-whatsapp

# Email Channel (IMAP/SMTP)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# MCP Server Keys (set as needed for catalog servers)
BRAVE_API_KEY=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Language (en, hi, es, zh, fr)
PAGAL_LANG=en
